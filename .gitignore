data/raw/

# Keep processed research data ignored by default, but allow the exact bounded
# quick_teeth subset used by the executable notebook to be versioned so a fresh
# clone can run the notebook without downloading the full source dataset.
data/processed/*
!data/processed/quick_teeth/
!data/processed/quick_teeth/**

data/TED3/
data/ted3/
data/incoming/

# Already-extracted TED3 research datasets — authoritative local inputs, never commit.
data/train/
data/test/
data/TED3-unlabeled-data-15k-pseudo-mask/

assets/checkpoints/
reproduction/assets/checkpoints/
reproduction/assets/dataset/
outputs/full/
outputs/inference/
*.pth
*.tar
*.tar.gz
*.zip

# Large TED3 archive inputs — retain locally for provenance only, never commit/package.
TED3-train.tar
TED3-test.tar
TED3-unlabeled-data-15k-pseudo-mask.tar
